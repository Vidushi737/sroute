# =========================================================================
# SROUTE ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your actual credentials.
# =========================================================================

# Database Connection (Supabase Remote Connection String)
# Format: jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?stringtype=unspecified
SUPABASE_DB_URL=jdbc:postgresql://db.[YOUR_PROJECT_REF].supabase.co:5432/postgres?stringtype=unspecified
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=[YOUR_SUPABASE_DATABASE_PASSWORD]

# Supabase Authentication Issuer
# Format: https://[YOUR_PROJECT_REF].supabase.co/auth/v1
SUPABASE_ISSUER_URI=https://[YOUR_PROJECT_REF].supabase.co/auth/v1

# Groq AI Service Key (For travel plan generation)
GROQ_API_KEY=[YOUR_GROQ_API_KEY]
